{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Live Server (auto-reload)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 8080
    },
    {
      "name": "Serve (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "-p", "3000", "."],
      "port": 3000
    }
  ]
}
