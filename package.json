{
  "name": "barunmaum-website",
  "version": "0.1.0",
  "private": true,
  "description": "서울바른마음치과 공식 홈페이지 (정적 HTML/CSS/JS)",
  "scripts": {
    "dev": "live-server --port=8080 --no-browser",
    "start": "npm run dev",
